# Force LF line endings for all text files (Git for Windows compatibility)
* text=auto eol=lf

# Explicitly declare text files to normalize
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.sql   text eol=lf
*.prisma text eol=lf
*.env   text eol=lf
*.conf  text eol=lf
*.sh    text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf

# Binary files - never modify line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
